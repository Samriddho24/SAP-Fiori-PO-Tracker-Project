# ZFI_PO_TRACKER — Environment Configuration
# Copy this file to .env and fill in your values
# Student: Samriddho Kar | Roll No: 23053296

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENV=development

# ── SAP BTP Configuration ────────────────────────────────────────────────────
BTP_SUBACCOUNT=kml-fiori-prod
BTP_CF_REGION=ap10
BTP_ORG=kml-org
BTP_SPACE=dev

# ── S/4HANA Connection ───────────────────────────────────────────────────────
S4_HOST=https://your-s4hana-host.example.com
S4_CLIENT=100
S4_USER=your_user
S4_PASSWORD=your_password

# ── SAP IAS (Identity Auth Service) ─────────────────────────────────────────
IAS_TENANT=https://kml.accounts.ondemand.com
IAS_CLIENT_ID=your_client_id
IAS_CLIENT_SECRET=your_client_secret

# ── BTP Destination ───────────────────────────────────────────────────────────
DESTINATION_NAME=KML_S4_PROD

# ── BTP Alert Notification ────────────────────────────────────────────────────
ALERT_NOTIFICATION_URL=https://alertnotification.cfapps.ap10.hana.ondemand.com
ALERT_CLIENT_ID=your_alert_client_id
ALERT_CLIENT_SECRET=your_alert_client_secret

# ── KML Company Settings ──────────────────────────────────────────────────────
KML_COMPANY_CODE=KML1
KML_PLANTS=KP01,KP02,KP03
KML_PURCHASING_ORG=KML_PO
KML_SALES_ORG=KSO1
OVERDUE_ALERT_THRESHOLD_DAYS=30
